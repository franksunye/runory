  "formDefinitions": [
    {
      "formKey": "service-deliverable-checklist",
      "name": "Service Deliverable Checklist",
      "schema": {
        "blocks": [
          {
            "block_type": "header",
            "id": "hdr-1",
            "label": "Pre-Service Checklist"
          },
          {
            "block_type": "checklist",
            "id": "cl-pre-service",
            "label": "Pre-Service Safety Checks",
            "required_count": 4,
            "items": [
              { "id": "cl-1", "label": "Safety gear inspected and worn", "required": true, "pass_fail_na": true },
              { "id": "cl-2", "label": "Work area secured and marked", "required": true, "pass_fail_na": true },
              { "id": "cl-3", "label": "Equipment power isolated", "required": true, "pass_fail_na": true },
              { "id": "cl-4", "label": "Customer notified of work commencement", "required": true, "pass_fail_na": true }
            ]
          },
          {
            "block_type": "header",
            "id": "hdr-2",
            "label": "Service Execution"
          },
          {
            "block_type": "field",
            "id": "fld-work-performed",
            "field_key": "work_performed",
            "field_type": "text",
            "label": "Work Performed",
            "required": true
          },
          {
            "block_type": "field",
            "id": "fld-parts-used",
            "field_key": "parts_used",
            "field_type": "text",
            "label": "Parts / Materials Used",
            "required": false
          },
          {
            "block_type": "field",
            "id": "fld-system-status",
            "field_key": "system_status_after_service",
            "field_type": "select",
            "label": "System Status After Service",
            "required": true,
            "options": ["operational", "monitoring", "needs_followup", "failed"]
          },
          {
            "block_type": "header",
            "id": "hdr-3",
            "label": "Evidence & Sign-off"
          },
          {
            "block_type": "evidence",
