{
  "name": "@runory/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "runory": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "runory": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "mcp:smoke": "tsx src/mcp-smoke.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@runory/shared": "workspace:*",
    "fastify": "^5.6.2",
    "pino": "^10.1.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
