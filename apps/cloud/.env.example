# Platform Cloud 环境配置模板
# 复制为 .env.local 后填入真实值；.env.local 不会被提交（见 .gitignore）
#
# 架构共识：同一份代码同时支持本地 SQLite 与云端 Turso，零代码切换。
#   - 本地开发：仅需 LIBSQL_URL=file:... （或完全不配，默认使用本地文件）
#   - 云端生产：LIBSQL_URL=libsql://... + LIBSQL_AUTH_TOKEN=...

# ===== 数据库（@libsql/client，本地 SQLite / 云端 Turso 二选一）=====

# ── 模式 A：本地 SQLite（默认，零配置即可开发）──
# 不设任何 LIBSQL_* 变量时，默认使用 file:${cwd}/data/platform.db
# 如需指定路径，取消下一行注释：
# LIBSQL_URL=file:./data/platform.db

# ── 模式 B：云端 Turso（生产 / 共享数据库）──
# 数据表按下方 SaaS / Runory 子系统前缀区分所有权
# LIBSQL_URL=libsql://your-platform-db.turso.io
# LIBSQL_AUTH_TOKEN=your_turso_auth_token

# ===== 部署模式 =====

# cloud: 共享数据库，业务表在部署时预创建，模块安装仅注册元数据
# local: 独立数据库，业务表在模块安装时创建（默认）
# PLATFORM_DEPLOYMENT_MODE=local

# ===== 表命名空间（与共享 Turso 库的其它项目隔离）=====

# 数据库基础设施（迁移账本）
# SYSTEM_TABLE_PREFIX=sys_

# 可复用 SaaS Core（身份、租户、授权、配额、审计）
# SAAS_TABLE_PREFIX=saas_

# Runory 元数据与安装运行时
# RUNORY_RUNTIME_TABLE_PREFIX=runory_runtime_

# Runory Catalog 与发布控制平面
# RUNORY_CATALOG_TABLE_PREFIX=runory_catalog_

# 历史迁移 0001-0010 的兼容前缀；新表不得使用
# PLATFORM_TABLE_PREFIX=platform_

# 业务表前缀（模块迁移创建的 customer / contact 等业务表）
# 默认 runory_business_（Module 拥有的 Runory 业务数据）
# 其他业务部署时改为对应品牌前缀，如 acme_business_
# BUSINESS_TABLE_PREFIX=runory_business_
# 兼容旧版（仍可用）：RUNORY_BUSINESS_TABLE_PREFIX

# ===== 会话 =====

# Session cookie 名称（默认 platform_session）
# PLATFORM_SESSION_COOKIE=platform_session

# 本地 SQLite 数据库文件名（默认 platform.db）
# PLATFORM_DB_FILENAME=platform.db

# ===== 身份信任头（反向代理 / SSO 场景）=====

# 启用后从 x-platform-user-id / x-platform-user-email / x-platform-user-name 头读取身份
# PLATFORM_TRUST_IDENTITY_HEADERS=false
# 兼容旧版（仍可用）：RUNORY_TRUST_IDENTITY_HEADERS

# 确认反向代理已验证（剥离客户端传入的身份头并重新注入）。
# 启用 PLATFORM_TRUST_IDENTITY_HEADERS 时必须设为 true，否则启动时会打印警告。
# 信任头可被任意客户端伪造，仅可在已验证的反向代理后方启用。
# PLATFORM_TRUST_PROXY_VERIFIED=false

# ===== 开发引导 =====

# 显式开启开发引导回退（自动以本地 owner 身份登录、自动创建 workspace 租户）。
# 仅用于本地开发；生产、staging、test 等环境切勿设置。
# 不再依赖 NODE_ENV，避免 NODE_ENV 未设置或为非 production 值时意外放开鉴权。
# PLATFORM_DEV_BOOTSTRAP=false

# ===== 邮件 =====

# OTP 邮件发送服务地址（生产环境必填）
# PLATFORM_MAIL_PROVIDER_URL=
# 兼容旧版（仍可用）：RUNORY_MAIL_PROVIDER_URL

# 在页面上返回 OTP 验证码（而非发送邮件）。
# 设为 true 时，即使在 production 环境也会跳过邮件发送、直接将 6 位验证码
# 返回到登录页面，方便尚未集成邮件服务的早期部署端到端使用。
# 本地开发（NODE_ENV !== production）始终返回验证码，无需设置此项。
# 注意：开启后会同时跳过 OTP 请求的速率限制，仅供内部测试使用。
# PLATFORM_OTP_RETURN_DEV_CODE=false

# ===== 平台管理 =====

# 平台管理员邮箱（逗号分隔，可访问 /admin 平台管理面板）
# PLATFORM_ADMIN_EMAILS=admin@example.com,ops@example.com

# ===== MCP Server =====

# Cloud API 基址（MCP stdio server 通过 HTTP fetch 调用 API）
# 本地开发默认 http://localhost:3000
# PLATFORM_API_BASE=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# Voice Intake / Retell
# ═══════════════════════════════════════════════════════════════

# Retell Agent 与 Runory Workspace 的映射标识
# RETELL_AGENT_ID=agent_xxx

# Retell Custom Function 的静态 Bearer 凭证（至少 32 随机字节）
# 在 Retell Tool Header 中配置：Authorization: Bearer <value>
# RETELL_TOOL_SECRET=

# Retell 指定用于 webhook 签名的 API Key。真实 lifecycle webhook 必需；
# RETELL_WEBHOOK_SECRET 仍作为兼容别名，但新配置优先使用 RETELL_API_KEY。
# RETELL_API_KEY=
# RETELL_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════
# Workspace customer payments / Stripe
# ═══════════════════════════════════════════════════════════════

# Stripe server key and webhook signing secret. Never expose either to the browser.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Explicit test/live isolation. The key prefix must match this mode.
# STRIPE_PAYMENT_MODE=test
# v0.5 supports one settlement currency per configured Workspace.
# STRIPE_PAYMENT_CURRENCY=USD

# v0.5 closure maps exactly one Workspace to one Stripe provider account.
# Use the canonical Workspace ID and a stable internal Provider Account ID.
# STRIPE_PAYMENT_WORKSPACE_ID=ws_...
# STRIPE_PAYMENT_PROVIDER_ACCOUNT_ID=payment_provider_stripe_test

# Optional Stripe account reference. For a direct platform account, leave unset.
# For future Connect isolation this is the Stripe acct_... identifier.
# STRIPE_ACCOUNT_ID=acct_...

# ═══════════════════════════════════════════════════════════════
# Runory SaaS subscription billing / Stripe Billing
# ═══════════════════════════════════════════════════════════════

# These credentials belong to Runory's own merchant account. They are
# deliberately separate from Workspace customer-payment configuration above.
# RUNORY_BILLING_STRIPE_SECRET_KEY=sk_test_...
# RUNORY_BILLING_STRIPE_WEBHOOK_SECRET=whsec_...
# RUNORY_BILLING_STRIPE_MODE=test

# Server-owned recurring Price allowlist. Browsers submit plan IDs, never Price IDs.
# RUNORY_BILLING_PRO_PRICE_ID=price_...

# Public application origin used for Checkout and Customer Portal return URLs.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
