{
  "name": "runory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @runory/cloud dev",
    "dev:cloud": "pnpm --filter @runory/cloud dev",
    "dev:mcp": "pnpm --filter @runory/mcp dev",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "reset": "node scripts/dev-reset.mjs",
    "mcp": "pnpm --filter @runory/mcp start"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
